# ============================================
# Route Builder - 환경 변수 (샘플)
# ============================================

# Naver Maps API (https://console.ncloud.com/)
# 중요: ncpKeyId 파라미터 사용 (2025 업그레이드 이후)
VITE_NAVER_MAP_CLIENT_ID=your_naver_client_id_here
VITE_NAVER_MAP_CLIENT_SECRET=your_naver_client_secret_here

# vworld API (https://api.vworld.kr/)
VITE_VWORLD_API_KEY=your_vworld_api_key_here

# 지도 엔진 선택: "naver" 또는 "leaflet" (vworld)
VITE_MAP_ENGINE=naver

# Anthropic Claude API (위성사진 AI 분석용)
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Overpass API (OSM 도로 데이터 조회 - 키 불필요)
VITE_OVERPASS_API_URL=https://overpass-api.de/api/interpreter
